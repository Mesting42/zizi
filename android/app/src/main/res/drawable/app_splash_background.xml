<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:centerColor="#17131F"
                android:endColor="#111016"
                android:startColor="#1A1621" />
        </shape>
    </item>
    <item
        android:bottom="-180dp"
        android:left="-80dp"
        android:right="-80dp"
        android:top="420dp">
        <shape android:shape="oval">
            <gradient
                android:centerColor="#1A8D4E68"
                android:endColor="#008D4E68"
                android:gradientRadius="280dp"
                android:type="radial" />
        </shape>
    </item>
</layer-list>
